{
  "name": "aroma-print-server",
  "version": "1.0.0",
  "description": "Local thermal print server for Aroma Ops",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:pkg": "pkg . --targets node18-macos-x64,node18-win-x64 --out-path ./dist"
  },
  "pkg": {
    "assets": [
      ".certs/**/*"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.4",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "pdf-to-printer": "^1.1.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
