{
  "name": "aromas",
  "version": "0.1.0",
  "description": "ByteBusiness POS Desktop — Point of Sale for vendors",
  "author": "Rahul Dara <rahuldara.iitbombay@gmail.com>",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "electron-builder install-app-deps",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "concurrently -n next,electron -c blue,green \"next dev\" \"wait-on http://localhost:3000/api/health && electron .\"",
    "electron:build:mac": "next build && npm run electron:prepare && npm run electron:compile && electron-builder --mac --arm64",
    "electron:build:win": "next build && npm run electron:prepare && npm run electron:compile && electron-builder --win --x64 --arm64",
    "electron:prepare": "node scripts/prepare-electron.js"
  },
  "dependencies": {
    "@cashfreepayments/cashfree-js": "^1.0.6",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "better-sqlite3": "^11.9.0",
    "cashfree-pg": "^5.1.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.34.4",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "qz-tray": "^2.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.7.0",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}