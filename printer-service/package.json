{
  "name": "aroma-printer-service",
  "version": "1.0.0",
  "description": "Local ESC/POS thermal printer service for Aroma Dhaba",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs aroma-printer-service"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-thermal-printer": "^4.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
